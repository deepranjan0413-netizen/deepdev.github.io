rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Aggregated star ratings — anyone can read, nobody writes directly
    // (only the onRatingWrite Cloud Function trust-writes these).
    match /ratingSummaries/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Individual ratings — public read (so buyers can see reviews),
    // but a person can only ever write their own rating, and only if
    // they're signed in with Google.
    match /products/{productId}/ratings/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId
                             && request.resource.data.stars is int
                             && request.resource.data.stars >= 1
                             && request.resource.data.stars <= 5;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Orders and payment records — server (Cloud Functions, via the Admin
    // SDK) bypasses rules entirely. Clients get zero direct access, since
    // this is where payment status and customer details live.
    match /orders/{orderId} {
      allow read, write: if false;
    }
  }
}
